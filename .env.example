# 複製成 .env（本機測試用）或填到 Render 的 Environment
# ── LINE（官方帳號 → Messaging API，全部免費）──
LINE_CHANNEL_ACCESS_TOKEN=你的_channel_access_token
LINE_CHANNEL_SECRET=你的_channel_secret

# ── Google Gemini（AI Studio 免費金鑰）──
GEMINI_API_KEY=你的_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Google 試算表後端（Apps Script Web App）──
SHEET_WEBAPP_URL=你的_apps_script_網頁應用程式URL
SHEET_TOKEN=跟_apps_script_裡_TOKEN_一模一樣的密碼
